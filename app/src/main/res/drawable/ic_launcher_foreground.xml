<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground layer for the adaptive launcher icon: a four-point spark with
    nested diamonds (red -> orange -> gold -> white) and a small companion dot,
    matching the app logo.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer four-point spark (concave sides pinched toward the centre). -->
    <path
        android:fillColor="#F5333A"
        android:pathData="M54,9 Q54,54 99,54 Q54,54 54,99 Q54,54 9,54 Q54,54 54,9 Z" />

    <!-- Nested diamonds, each a rotated square, centred. -->
    <path
        android:fillColor="#F4661F"
        android:pathData="M54,24 L84,54 L54,84 L24,54 Z" />
    <path
        android:fillColor="#FBBA1F"
        android:pathData="M54,33 L75,54 L54,75 L33,54 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,41 L67,54 L54,67 L41,54 Z" />

    <!-- Small companion dot, top-right: pink ring with a white centre. -->
    <path
        android:fillColor="#F6A9A0"
        android:pathData="M70,30 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M74,30 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0 Z" />
</vector>
